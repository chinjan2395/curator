# Dev server only: where Vite forwards /api/* (Node runs this, not the browser).
# - Local: omit this or use http://127.0.0.1:8000
# - Docker Compose frontend service: http://backend:8000 (set in docker-compose.yml)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Browser runtime base URL for API/embed assets.
# - If frontend and backend are same origin, omit this.
# - If frontend is on a different domain, set this to backend origin.
# VITE_API_BASE_URL=https://your-backend-domain.com
