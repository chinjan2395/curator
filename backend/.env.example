APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=curator
DB_USERNAME=root
DB_PASSWORD=root

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
# Email verification is off by default when MAIL_MAILER is log or array.
# Set REQUIRE_EMAIL_VERIFICATION=true after SMTP is configured for production.
# REQUIRE_EMAIL_VERIFICATION=true
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google OAuth (YouTube + Google connect + Google login)
# Create credentials at https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID, Web application).
# Add redirect URIs: .../api/social/callback/youtube, .../api/social/callback/google, .../api/auth/social/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/social/callback/youtube"

# Facebook OAuth (Facebook + Instagram connect + Facebook login)
# Create app at https://developers.facebook.com/ → Add Instagram product for Instagram.
# Add redirect URIs: ${APP_URL}/api/social/callback/facebook, ${APP_URL}/api/auth/social/facebook/callback
#
# Social LOGIN uses FACEBOOK_CLIENT_ID / FACEBOOK_CLIENT_SECRET below (backend .env only).
# Must be the numeric "App ID" from Meta → App settings → Basic — NOT the App Secret (long hex string).
# Never paste a Google OAuth client ID (*.apps.googleusercontent.com) here — Facebook login will stay hidden.
# You do not need FACEBOOK_APP_ID. (Optional: some docs call it "App ID"; if you named your env key FACEBOOK_APP_ID instead of FACEBOOK_CLIENT_ID, the app reads that too.) Spaces in the ID are stripped at load.
# Wrong value → Facebook shows "Invalid App ID". Ensure .env has no stray quotes/spaces; run config:clear after edits.
# Frontend dev: set frontend/.env VITE_API_PROXY_TARGET=http://127.0.0.1:8000 so /api hits this backend (not a stale default).
#
# Facebook Login for Business (business-type apps): email + public_profile alone are not enough — Meta requires at least one
# supported business permission per login. When FACEBOOK_LOGIN_CONFIG_ID is unset, Curator requests pages_show_list with email/public_profile.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/api/social/callback/facebook"

# Optional — Facebook Login for Business: Configuration ID from App Dashboard → Facebook Login for Business → Configurations.
# When set, login uses config_id (permissions come from that configuration). When empty, login requests scopes below in code.
# FACEBOOK_LOGIN_CONFIG_ID=


# Twitter (X) OAuth 2 (social connect + Twitter login)
# Create app at https://developer.twitter.com/ → OAuth 2.0 with PKCE.
# Add callback URIs: ${APP_URL}/api/social/callback/twitter, ${APP_URL}/api/auth/social/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI="${APP_URL}/api/social/callback/twitter"

# GitHub OAuth (login only)
# Create app at https://github.com/settings/applications/new
# Authorization callback URL: ${APP_URL}/api/auth/social/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/api/auth/social/github/callback"

# AI content generation (stub | groq | ollama)
AI_DRIVER=stub
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# TikTok OAuth
# Create app at https://developers.tiktok.com/ and enable Login Kit + Content Posting / Data scopes as needed.
# Add redirect URI: ${APP_URL}/api/social/callback/tiktok
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI="${APP_URL}/api/social/callback/tiktok"
